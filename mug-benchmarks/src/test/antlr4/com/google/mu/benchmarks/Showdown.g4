grammar Showdown;

// 1. IP Address Rule
ip: INT '.' INT '.' INT '.' INT EOF;

// 2. Quoted String Rule
quotedString: QUOTED_STRING EOF;

// 3. Case-Sensitive Keywords Rule
keyword: KW_SYNCHRONIZED | KW_FALLTHROUGH | KW_IMPLEMENTS | KW_INSTANCEOF | KW_INTERFACE | KW_PROTECTED | KW_TRANSIENT | KW_NAMESPACE | KW_CONSTEXPR | KW_TYPEALIAS | KW_COMPANION | KW_COROUTINE | KW_ABSTRACT | KW_CONTINUE | KW_STRICTFP | KW_VOLATILE | KW_NONLOCAL | KW_EXPLICIT | KW_OPERATOR | KW_TEMPLATE | KW_TYPENAME | KW_DECLTYPE | KW_NOEXCEPT | KW_REQUIRES | KW_FUNCTION | KW_DEBUGGER | KW_EXTERNAL | KW_INTERNAL | KW_OVERRIDE | KW_DELEGATE | KW_UNSIGNED | KW_REGISTER | KW_BOOLEAN | KW_DEFAULT | KW_EXTENDS | KW_FINALLY | KW_PACKAGE | KW_PRIVATE | KW_TYPEDEF | KW_VIRTUAL | KW_NULLPTR | KW_ALIGNAS | KW_ALIGNOF | KW_CONCEPT | KW_PERMITS | KW_VARARGS | KW_REIFIED | KW_SUSPEND | KW_CHANNEL | KW_SELECT | KW_INSERT | KW_UPDATE | KW_DELETE | KW_CREATE | KW_HAVING | KW_ASSERT | KW_DOUBLE | KW_IMPORT | KW_NATIVE | KW_PUBLIC | KW_RETURN | KW_STATIC | KW_SWITCH | KW_THROWS | KW_LAMBDA | KW_EXCEPT | KW_GLOBAL | KW_STRUCT | KW_SIZEOF | KW_INLINE | KW_FRIEND | KW_UNSAFE | KW_EXPORT | KW_MODULE | KW_RECORD | KW_SEALED | KW_RWLOCK | KW_ATOMIC | KW_SIGNED | KW_ALTER | KW_WHERE | KW_GROUP | KW_ORDER | KW_LIMIT | KW_BREAK | KW_CATCH | KW_CLASS | KW_FLOAT | KW_SHORT | KW_SUPER | KW_WHILE | KW_ASYNC | KW_AWAIT | KW_RAISE | KW_YIELD | KW_UNION | KW_USING | KW_TRAIT | KW_MATCH | KW_CRATE | KW_DEFER | KW_RANGE | KW_MUTEX | KW_DROP | KW_BYTE | KW_CASE | KW_CHAR | KW_ELSE | KW_ENUM | KW_GOTO | KW_LONG | KW_THIS | KW_VOID | KW_ELIF | KW_PASS | KW_WITH | KW_LOOP | KW_MOVE | KW_SELF | KW_FROM;
keywords: keyword (',' keyword)* EOF;

// 4. Case-Insensitive Keywords Rule
keywordIgnoreCase: KW_SYNCHRONIZED_IC | KW_FALLTHROUGH_IC | KW_IMPLEMENTS_IC | KW_INSTANCEOF_IC | KW_INTERFACE_IC | KW_PROTECTED_IC | KW_TRANSIENT_IC | KW_NAMESPACE_IC | KW_CONSTEXPR_IC | KW_TYPEALIAS_IC | KW_COMPANION_IC | KW_COROUTINE_IC | KW_ABSTRACT_IC | KW_CONTINUE_IC | KW_STRICTFP_IC | KW_VOLATILE_IC | KW_NONLOCAL_IC | KW_EXPLICIT_IC | KW_OPERATOR_IC | KW_TEMPLATE_IC | KW_TYPENAME_IC | KW_DECLTYPE_IC | KW_NOEXCEPT_IC | KW_REQUIRES_IC | KW_FUNCTION_IC | KW_DEBUGGER_IC | KW_EXTERNAL_IC | KW_INTERNAL_IC | KW_OVERRIDE_IC | KW_DELEGATE_IC | KW_UNSIGNED_IC | KW_REGISTER_IC | KW_BOOLEAN_IC | KW_DEFAULT_IC | KW_EXTENDS_IC | KW_FINALLY_IC | KW_PACKAGE_IC | KW_PRIVATE_IC | KW_TYPEDEF_IC | KW_VIRTUAL_IC | KW_NULLPTR_IC | KW_ALIGNAS_IC | KW_ALIGNOF_IC | KW_CONCEPT_IC | KW_PERMITS_IC | KW_VARARGS_IC | KW_REIFIED_IC | KW_SUSPEND_IC | KW_CHANNEL_IC | KW_SELECT_IC | KW_INSERT_IC | KW_UPDATE_IC | KW_DELETE_IC | KW_CREATE_IC | KW_HAVING_IC | KW_ASSERT_IC | KW_DOUBLE_IC | KW_IMPORT_IC | KW_NATIVE_IC | KW_PUBLIC_IC | KW_RETURN_IC | KW_STATIC_IC | KW_SWITCH_IC | KW_THROWS_IC | KW_LAMBDA_IC | KW_EXCEPT_IC | KW_GLOBAL_IC | KW_STRUCT_IC | KW_SIZEOF_IC | KW_INLINE_IC | KW_FRIEND_IC | KW_UNSAFE_IC | KW_EXPORT_IC | KW_MODULE_IC | KW_RECORD_IC | KW_SEALED_IC | KW_RWLOCK_IC | KW_ATOMIC_IC | KW_SIGNED_IC | KW_ALTER_IC | KW_WHERE_IC | KW_GROUP_IC | KW_ORDER_IC | KW_LIMIT_IC | KW_BREAK_IC | KW_CATCH_IC | KW_CLASS_IC | KW_FLOAT_IC | KW_SHORT_IC | KW_SUPER_IC | KW_WHILE_IC | KW_ASYNC_IC | KW_AWAIT_IC | KW_RAISE_IC | KW_YIELD_IC | KW_UNION_IC | KW_USING_IC | KW_TRAIT_IC | KW_MATCH_IC | KW_CRATE_IC | KW_DEFER_IC | KW_RANGE_IC | KW_MUTEX_IC | KW_DROP_IC | KW_BYTE_IC | KW_CASE_IC | KW_CHAR_IC | KW_ELSE_IC | KW_ENUM_IC | KW_GOTO_IC | KW_LONG_IC | KW_THIS_IC | KW_VOID_IC | KW_ELIF_IC | KW_PASS_IC | KW_WITH_IC | KW_LOOP_IC | KW_MOVE_IC | KW_SELF_IC | KW_FROM_IC;
keywordsIgnoreCase: keywordIgnoreCase (',' keywordIgnoreCase)* EOF;

// 5. Calculator Rule
calculator: calcExpr EOF;

calcExpr: calcExpr ('*'|'/') calcExpr
        | calcExpr ('+'|'-') calcExpr
        | '(' calcExpr ')'
        | '-'? INT
        ;

nestedCommentRoot: nestedComment EOF;
nestedComment: OPEN_COMMENT ( TEXT | nestedComment )* CLOSE_COMMENT;

usPhone: US_PHONE_TOKEN EOF;
usPhoneList: US_PHONE_TOKEN* EOF;

select_ic: SELECT | SELECT_IC;
insert_ic: INSERT | INSERT_IC;
update_ic: UPDATE | UPDATE_IC;
delete_ic: DELETE | DELETE_IC;
create_ic: CREATE | CREATE_IC;
drop_ic: DROP | DROP_IC;
alter_ic: ALTER | ALTER_IC;
where_ic: WHERE | WHERE_IC;
group_ic: GROUP | GROUP_IC;
order_ic: ORDER | ORDER_IC;
having_ic: HAVING | HAVING_IC;
limit_ic: LIMIT | LIMIT_IC;

// Lexer Rules
QUOTED_STRING: '"' (ESC | ~[\\"])* '"';

fragment ESC: '\\' .;
INT: [0-9]+;



US_PHONE_TOKEN: '(' [0-9] [0-9] [0-9] ')' [0-9] [0-9] [0-9] '-' [0-9] [0-9] [0-9] [0-9];












// 5. Calculator Rule
calculator: calcExpr EOF;

calcExpr: calcExpr ('*'|'/') calcExpr
        | calcExpr ('+'|'-') calcExpr
        | '(' calcExpr ')'
        | '-'? INT
        ;

nestedCommentRoot: nestedComment EOF;
nestedComment: OPEN_COMMENT ( TEXT | nestedComment )* CLOSE_COMMENT;

usPhone: US_PHONE_TOKEN EOF;
usPhoneList: US_PHONE_TOKEN* EOF;

select_ic: KW_SELECT | KW_SELECT_IC;
insert_ic: KW_INSERT | KW_INSERT_IC;
update_ic: KW_UPDATE | KW_UPDATE_IC;
delete_ic: KW_DELETE | KW_DELETE_IC;
create_ic: KW_CREATE | KW_CREATE_IC;
drop_ic: KW_DROP | KW_DROP_IC;
alter_ic: KW_ALTER | KW_ALTER_IC;
where_ic: KW_WHERE | KW_WHERE_IC;
group_ic: KW_GROUP | KW_GROUP_IC;
order_ic: KW_ORDER | KW_ORDER_IC;
having_ic: KW_HAVING | KW_HAVING_IC;
limit_ic: KW_LIMIT | KW_LIMIT_IC;

// Lexer Rules
QUOTED_STRING: '"' (ESC | ~[\\"])* '"';

fragment ESC: '\\' .;
INT: [0-9]+;



US_PHONE_TOKEN: '(' [0-9] [0-9] [0-9] ')' [0-9] [0-9] [0-9] '-' [0-9] [0-9] [0-9] [0-9];















